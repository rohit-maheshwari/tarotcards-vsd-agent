# Backend Environment Variables
# Copy this to .env for local development

# MongoDB Connection String
# Get a free MongoDB Atlas cluster at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/TarotCardsVSD?retryWrites=true&w=majority

# Server Port (optional, defaults to 8000)
PORT=8000

# Frontend URL for CORS (optional, defaults to allow all origins)
FRONTEND_URL=http://localhost:3000

# Google Client ID for authentication
GOOGLE_CLIENT_ID=your_google_client_id_here

# Node Environment
NODE_ENV=development
